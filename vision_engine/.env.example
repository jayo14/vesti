# Copy to .env and adjust as needed.
VISION_HOST=0.0.0.0
VISION_PORT=8100
VISION_LOG_LEVEL=info
VISION_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
VISION_DEVICE=cpu

# Hosted inference (leave as none to use local/mock mode)
VISION_HOSTED_PROVIDER=none
VISION_HOSTED_API_KEY=
VISION_HOSTED_ENDPOINT=

# Model artifact paths (populated in Stage 1+)
VISION_MODELS_DIR=./models
VISION_DETECT_MODEL_PATH=./models/detection.onnx
VISION_POSE_MODEL_PATH=./models/pose.onnx
VISION_PARSE_MODEL_PATH=./models/parsing.onnx
VISION_GARMENT_SEG_MODEL_PATH=./models/garment_segment.onnx
VISION_TRYON_MODEL_PATH=./models/tryon.onnx
VISION_ENHANCE_MODEL_PATH=./models/enhance.onnx
