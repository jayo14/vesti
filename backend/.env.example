# ── Django Core ──────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=.fly.dev,.vesti.app,localhost
DATABASE_URL=postgres://user:password@host:5432/vesti

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://vesti.app

# ── JWT ──────────────────────────────────────────────────────
# Optional overrides (defaults: access 1h, refresh 7d)
# JWT_ACCESS_LIFETIME_MINUTES=60
# JWT_REFRESH_LIFETIME_DAYS=7

# ── Email ────────────────────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=SG.xxxxx
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@vesti.app

# ── AI / LLM (OpenRouter) ───────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Vision Engine (CV pipeline) ──────────────────────────────
VISION_ENGINE_URL=http://localhost:8100

# ── ALATPay (payments) ───────────────────────────────────────
ALATPAY_PUBLIC_KEY=your-public-key
ALATPAY_SECRET_KEY=your-secret-key
ALATPAY_BUSINESS_ID=your-business-id
ALATPAY_WEBHOOK_SECRET=your-webhook-secret
ALATPAY_SPLIT_CODE=optional-split-code

# ── AWS S3 (file uploads) ────────────────────────────────────
# When AWS_STORAGE_BUCKET_NAME is set, uploaded files go to S3 instead of local disk.
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=vesti-uploads
AWS_S3_REGION_NAME=us-east-1
# Optional: custom domain / CDN
# AWS_S3_CUSTOM_DOMAIN=cdn.vesti.app

# ── Redis / Caching ──────────────────────────────────────────
# When REDIS_URL is set, Django uses Redis for caching (recommended in production).
# Falls back to local-memory cache when empty.
REDIS_URL=redis://default:password@fly-redis.upstash.io:6379

# ── Analytics ────────────────────────────────────────────────
# Optional: log all events to a separate analytics Postgres schema.
# ANALYTICS_DATABASE_URL=postgres://user:password@host:5432/vesti_analytics
